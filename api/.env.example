# =============================================================================
# SENTINELS OF INTEGRITY — Backend Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

ENVIRONMENT=development
DEBUG=true
API_VERSION=v1
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql+asyncpg://sentinels:password@localhost:5432/sentinels_db

# Redis
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# JWT (RS256)
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
JWT_EXPIRY_SECONDS=3600

# AES-256-GCM
AES_KEY_PATH=./keys/aes.key

# ML Engine
ML_ENGINE_URL=http://localhost:8001
ML_TIMEOUT_SECONDS=10.0

# Blockchain (Polygon zkEVM)
BLOCKCHAIN_RPC_URL=https://rpc.cardona.zkevm-rpc.com
CONTENT_REGISTRY_ADDRESS=
INTEGRITY_HASH_ADDRESS=
BLOCKCHAIN_PRIVATE_KEY=

# HashiCorp Vault
VAULT_ENABLED=false
VAULT_URL=http://localhost:8200
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/sentinels

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
