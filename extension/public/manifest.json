{
  "manifest_version": 3,
  "name": "Sentinels of Integrity",
  "version": "0.1.0",
  "description": "AI-Powered Truth Guard — Real-time deepfake detection overlay for YouTube, X, and TikTok.",
  "permissions": ["activeTab", "storage", "alarms"],
  "host_permissions": ["https://www.youtube.com/*", "https://twitter.com/*", "https://x.com/*", "https://www.tiktok.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "background": { "service_worker": "service_worker.js", "type": "module" },
  "content_scripts": [{
    "matches": ["https://www.youtube.com/*", "https://twitter.com/*", "https://x.com/*", "https://www.tiktok.com/*"],
    "js": ["content_script.js"],
    "css": ["overlay.css"],
    "run_at": "document_idle"
  }],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
